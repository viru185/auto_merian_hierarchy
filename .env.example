# Absolute or relative path to the source hierarchy Excel workbook that feeds the pipeline.
DATA_IN="data/Merian-Kept-Hierarchy-Combined.xlsx"

# Optional override for the generated PI Builder workbook; defaults to <DATA_IN>_PI_Builder.xlsx in the same folder.
DATA_OUT="data/Merian-Kept-Hierarchy-Combined_PI_Builder.xlsx"

# Location of the JSON file that acts as the hierarchy source of truth between runs.
JSON_FILE="data/merian_hierarchy.json"




# Directory where log files should be written; defaults to ./logs.
LOGS_DIR="logs"

# Specific log file path (auto-resolves under LOGS_DIR if unset).
LOGS_FILE="logs/app.log"

# Logging level for both console and file handlers (DEBUG, INFO, WARNING, etc.).
LOG_LEVEL="DEBUG"

# Toggle writing structured logs to disk (true/false).
LOG_TO_FILE="true"

# Toggle streaming logs to STDOUT (true/false).
LOG_TO_CONSOLE="true"
